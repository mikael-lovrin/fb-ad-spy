# ── Database ─────────────────────────────────────────────────────────────────
# Cloud (Supabase): get from Project Settings → Database → Connection string (URI)
# Local (SQLite):   leave blank — uses data/ads.db automatically
DATABASE_URL=

# ── Anthropic Claude (required for copy/image/video analysis) ─────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── OpenAI — only needed if USE_LOCAL_WHISPER=false ───────────────────────────
OPENAI_API_KEY=

# ── Facebook (optional — Playwright scraper doesn't need a token) ─────────────
FB_ACCESS_TOKEN=
FB_AD_ACCOUNT_ID=

# ── Whisper transcription ─────────────────────────────────────────────────────
# true  = faster-whisper runs locally (free — install: pip install faster-whisper)
# false = OpenAI Whisper API (~$0.006/min)
USE_LOCAL_WHISPER=true
WHISPER_MODEL_SIZE=small

# ── Collection defaults ───────────────────────────────────────────────────────
DEFAULT_COUNTRY=US
DEFAULT_COUNT=50
MIN_ADS_FOR_SWIPE=10
